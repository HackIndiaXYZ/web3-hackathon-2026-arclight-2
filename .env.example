# Mail-IQ Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to version control!

# ── Supabase (Required) ───────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Gmail OAuth (Required for live email sync) ────────────────────────────────
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Gmail API, then create OAuth 2.0 Client ID (Web application)
VITE_GMAIL_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
VITE_GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
VITE_GMAIL_REDIRECT_URI=http://localhost:5173/auth/callback

# ── AI APIs (Optional — app works in demo mode without these) ─────────────────
# Gemini: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (optional alternative): https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# ── App Configuration ─────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Mail-IQ
VITE_APP_VERSION=2.0.0

# ── Feature Flags (Optional) ──────────────────────────────────────────────────
VITE_ENABLE_VOICE_ALERTS=false
VITE_ENABLE_PWA=false
VITE_DEMO_MODE=true
